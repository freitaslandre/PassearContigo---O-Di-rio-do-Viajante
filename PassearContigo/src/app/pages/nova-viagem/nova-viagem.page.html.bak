<ion-header>
  <ion-toolbar>
    <ion-buttons slot="start">
      <ion-back-button defaultHref="/tabs/viagens"></ion-back-button>
    </ion-buttons>
    <ion-title>Nova Viagem</ion-title>
  </ion-toolbar>
</ion-header>

<ion-content class="ion-padding">
  <form [formGroup]="form" (ngSubmit)="criarViagem()">
    <!-- Foto de Capa -->
    <div class="foto-capa-section">
      <div class="foto-capa-preview" *ngIf="fotoCapaPreview">
        <img [src]="fotoCapaPreview" alt="Foto de Capa" />
        <ion-button
          color="danger"
          size="small"
          (click)="removerFotoCapa()"
          type="button"
        >
          <ion-icon slot="start" name="trash"></ion-icon>
          Remover
        </ion-button>
      </div>

      <div class="foto-capa-upload" *ngIf="!fotoCapaPreview">
        <ion-button
          expand="block"
          color="primary"
          (click)="tirarFotoCapa()"
          type="button"
        >
          <ion-icon slot="start" name="camera"></ion-icon>
          Tirar Foto de Capa
        </ion-button>
        <ion-button
          expand="block"
          color="medium"
          fill="outline"
          (click)="escolherFotoCapaDaGaleria()"
          type="button"
        >
          <ion-icon slot="start" name="images"></ion-icon>
          Escolher da Galeria
        </ion-button>
      </div>
    </div>

    <!-- Título -->
    <ion-item>
      <ion-label position="floating">Título da Viagem *</ion-label>
      <ion-input
        formControlName="titulo"
        type="text"
        placeholder="Ex: Lisboa 2024"
      ></ion-input>
    </ion-item>
    <ion-text color="danger" *ngIf="titulo?.invalid && titulo?.touched">
      <small *ngIf="titulo?.hasError('required')">Título é obrigatório</small>
      <small *ngIf="titulo?.hasError('minlength')">
        Mínimo 3 caracteres
      </small>
    </ion-text>

    <!-- Destino -->
    <ion-item>
      <ion-label position="floating">Destino *</ion-label>
      <ion-input
        formControlName="destino"
        type="text"
        placeholder="Ex: Portugal"
      ></ion-input>
    </ion-item>
    <ion-text color="danger" *ngIf="destino?.invalid && destino?.touched">
      <small *ngIf="destino?.hasError('required')">Destino é obrigatório</small>
    </ion-text>

    <!-- Data de Início -->
    <ion-item>
      <ion-label position="floating">Data de Início *</ion-label>
      <ion-input
        formControlName="dataInicio"
        type="date"
      ></ion-input>
    </ion-item>
    <ion-text color="danger" *ngIf="dataInicio?.invalid && dataInicio?.touched">
      <small *ngIf="dataInicio?.hasError('required')">
        Data de início é obrigatória
      </small>
    </ion-text>

    <!-- Data de Fim -->
    <ion-item>
      <ion-label position="floating">Data de Fim *</ion-label>
      <ion-input
        formControlName="dataFim"
        type="date"
      ></ion-input>
    </ion-item>
    <ion-text color="danger" *ngIf="dataFim?.invalid && dataFim?.touched">
      <small *ngIf="dataFim?.hasError('required')">
        Data de fim é obrigatória
      </small>
    </ion-text>
    <ion-text color="danger" *ngIf="form.hasError('datasInvalidas')">
      <small>A data de fim não pode ser anterior à data de início</small>
    </ion-text>

    <!-- Botões -->
    <div class="button-group">
      <ion-button
        expand="block"
        color="primary"
        type="submit"
        [disabled]="form.invalid"
      >
        <ion-icon slot="start" name="checkmark-circle"></ion-icon>
        Criar Viagem
      </ion-button>
      <ion-button
        expand="block"
        color="medium"
        type="button"
        (click)="cancelar()"
      >
        <ion-icon slot="start" name="close-circle"></ion-icon>
        Cancelar
      </ion-button>
    </div>
  </form>
</ion-content>
