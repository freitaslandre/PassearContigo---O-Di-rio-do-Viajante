<ion-header>
  <ion-toolbar>
    <ion-buttons slot="start">
      <ion-back-button [defaultHref]="'/tabs/viagens/' + viagemId"></ion-back-button>
    </ion-buttons>
    <ion-title>Editar Viagem</ion-title>
  </ion-toolbar>
</ion-header>

<ion-content class="ion-padding">
  <div *ngIf="carregando" class="loading-card">
    <ion-spinner name="crescent"></ion-spinner>
    <p>A carregar viagem...</p>
  </div>

  <ion-card *ngIf="!carregando && erro">
    <ion-card-content>
      <p>{{ erro }}</p>
      <ion-button expand="block" color="medium" (click)="cancelar()">Voltar</ion-button>
    </ion-card-content>
  </ion-card>

  <form *ngIf="!carregando && !erro" [formGroup]="form" (ngSubmit)="guardar()">
    <div class="foto-capa-section">
      <div class="foto-capa-preview" *ngIf="fotoCapaPreview">
        <img [src]="fotoCapaPreview" alt="Foto de capa">
        <ion-button color="danger" size="small" type="button" (click)="removerFotoCapa()">
          <ion-icon slot="start" name="trash-outline"></ion-icon>
          Remover
        </ion-button>
      </div>

      <div class="foto-capa-upload" *ngIf="!fotoCapaPreview">
        <ion-button expand="block" color="primary" type="button" (click)="tirarFotoCapa()">
          <ion-icon slot="start" name="camera-outline"></ion-icon>
          Tirar Foto de Capa
        </ion-button>
        <ion-button expand="block" color="medium" fill="outline" type="button" (click)="escolherFotoCapaDaGaleria()">
          <ion-icon slot="start" name="images-outline"></ion-icon>
          Escolher da Galeria
        </ion-button>
      </div>
    </div>

    <ion-item>
      <ion-label position="floating">Titulo da Viagem *</ion-label>
      <ion-input formControlName="titulo" type="text"></ion-input>
    </ion-item>
    <ion-text color="danger" *ngIf="titulo?.invalid && titulo?.touched">
      <small *ngIf="titulo?.hasError('required')">Titulo e obrigatorio</small>
      <small *ngIf="titulo?.hasError('minlength')">Minimo 3 caracteres</small>
    </ion-text>

    <ion-item>
      <ion-label position="floating">Destino *</ion-label>
      <ion-input formControlName="destino" type="text"></ion-input>
    </ion-item>
    <ion-text color="danger" *ngIf="destino?.invalid && destino?.touched">
      <small *ngIf="destino?.hasError('required')">Destino e obrigatorio</small>
    </ion-text>

    <ion-item>
      <ion-label position="floating">Descricao</ion-label>
      <ion-textarea formControlName="descricao" autoGrow="true"></ion-textarea>
    </ion-item>

    <ion-item>
      <ion-label position="floating">Estado</ion-label>
      <ion-select formControlName="status" interface="popover">
        <ion-select-option value="planejada">Planejada</ion-select-option>
        <ion-select-option value="em-andamento">Em andamento</ion-select-option>
        <ion-select-option value="concluida">Concluida</ion-select-option>
        <ion-select-option value="cancelada">Cancelada</ion-select-option>
      </ion-select>
    </ion-item>

    <ion-item>
      <ion-label position="floating">Data de Inicio *</ion-label>
      <ion-input formControlName="dataInicio" type="date"></ion-input>
    </ion-item>
    <ion-text color="danger" *ngIf="dataInicio?.invalid && dataInicio?.touched">
      <small *ngIf="dataInicio?.hasError('required')">Data de inicio e obrigatoria</small>
    </ion-text>

    <ion-item>
      <ion-label position="floating">Data de Fim *</ion-label>
      <ion-input formControlName="dataFim" type="date"></ion-input>
    </ion-item>
    <ion-text color="danger" *ngIf="dataFim?.invalid && dataFim?.touched">
      <small *ngIf="dataFim?.hasError('required')">Data de fim e obrigatoria</small>
    </ion-text>
    <ion-text color="danger" *ngIf="form.hasError('datasInvalidas')">
      <small>A data de fim nao pode ser anterior a data de inicio</small>
    </ion-text>

    <ion-note color="medium" class="dias-note" *ngIf="numeroDias > 0">
      Duracao: {{ numeroDias }} dias
    </ion-note>

    <div class="button-group">
      <ion-button expand="block" color="primary" type="submit" [disabled]="form.invalid">
        <ion-icon slot="start" name="save-outline"></ion-icon>
        Guardar Alteracoes
      </ion-button>
      <ion-button expand="block" color="medium" type="button" (click)="cancelar()">
        <ion-icon slot="start" name="close-circle-outline"></ion-icon>
        Cancelar
      </ion-button>
    </div>
  </form>
</ion-content>
